{
    "name": "venqore-station",
    "version": "1.0.0",
    "description": "VenQore POS Desktop Station - Hardware Control Bridge",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder",
        "build:win": "electron-builder --win",
        "build:portable": "electron-builder --win portable"
    },
    "author": "VenQore Electronics",
    "license": "MIT",
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.13.3",
        "png-to-ico": "^3.0.1"
    },
    "dependencies": {
        "app-builder-bin": "^4.2.0",
        "electron-pos-printer": "^1.3.6",
        "escpos": "^3.0.0-alpha.6",
        "escpos-usb": "^3.0.0-alpha.4",
        "jimp": "^0.16.1",
        "png2icons": "^2.0.1"
    },
    "build": {
        "appId": "com.amd.station",
        "productName": "VenQore Station",
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "assets/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": "assets/icon.ico",
            "uninstallerIcon": "assets/icon.ico"
        },
        "files": [
            "main.js",
            "preload.js",
            "shell.html",
            "shell.css",
            "shell-renderer.js",
            "loading.html",
            "error.html",
            "assets/**/*"
        ],
        "directories": {
            "output": "dist"
        }
    }
}