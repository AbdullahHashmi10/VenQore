# ╔══════════════════════════════════════════════════════════════════╗
# ║   VENQORE PRODUCTION ENVIRONMENT — Phase 8                       ║
# ║   Copy this to .env and fill in ALL values before deploying.     ║
# ║   NEVER commit a real .env file to version control.              ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Application ──────────────────────────────────────────────────────
APP_NAME=VenQore
APP_ENV=production
APP_KEY=                                       # php artisan key:generate
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://venqore.com
APP_DOMAIN=venqore.com                         # Used by TenantMiddleware for subdomain extraction
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────────────
LOG_CHANNEL=stack
# PRODUCTION: Set to 'daily,slack' to send ERROR+ logs to Slack immediately
# STAGING:    Set to 'daily' only
LOG_STACK=daily,slack
LOG_LEVEL=error                                # error in prod — fills disk if set to warning
LOG_DEPRECATIONS_CHANNEL=null
LOG_DAILY_DAYS=14                              # Keep 14 days of logs

# Slack error alerting (Pre-Launch §14)
# Create at: https://api.slack.com/apps → Incoming Webhooks → #venqore-alerts
LOG_SLACK_WEBHOOK_URL=                         # https://hooks.slack.com/services/T.../B.../...
LOG_SLACK_LEVEL=error                          # Only fire on error or above

# ── Database ─────────────────────────────────────────────────────────
# DigitalOcean Droplet — MySQL 8.0 on same server (separate later)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=venqore_production
DB_USERNAME=venqore_user
DB_PASSWORD=                                   # STRONG password — use: openssl rand -base64 32

# ── Session ───────────────────────────────────────────────────────────
# CRITICAL: Must be .venqore.com (with leading dot) for wildcard subdomain auth
SESSION_DRIVER=redis
SESSION_LIFETIME=480                           # 8 hours (POS working shift)
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.venqore.com                    # Leading dot = all subdomains
SESSION_SECURE_COOKIE=true                     # Requires HTTPS

# ── Cache & Queue ─────────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=venqore_
QUEUE_CONNECTION=redis                         # Processed by Laravel Horizon
BROADCAST_CONNECTION=log

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=                                # Set a password: requirepass in redis.conf
REDIS_PORT=6379
# Separate DBs per concern (0=default, 1=cache, 2=queue, 3=sessions)
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# ── File Storage — Cloudflare R2 ──────────────────────────────────────
# R2 is S3-compatible. ~$3/month for typical SaaS usage.
# Create bucket: venqore-assets in Cloudflare dashboard.
FILESYSTEM_DISK=r2
AWS_ACCESS_KEY_ID=                             # R2 API token — from Cloudflare dashboard
AWS_SECRET_ACCESS_KEY=                         # R2 API secret
AWS_DEFAULT_REGION=auto                        # R2 uses "auto"
AWS_BUCKET=venqore-assets
AWS_USE_PATH_STYLE_ENDPOINT=true               # Required for R2
AWS_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_URL=https://assets.venqore.com   # Custom domain for public asset URLs

# ── Mail — Postmark ───────────────────────────────────────────────────
# $1.50 per 1,000 emails. Excellent deliverability.
MAIL_MAILER=postmark
POSTMARK_TOKEN=                                # From postmark.com → Server → API Tokens
MAIL_FROM_ADDRESS=hello@venqore.com
MAIL_FROM_NAME=VenQore

# ── Lemon Squeezy Billing ─────────────────────────────────────────────
# All values from app.lemonsqueezy.com → Store → Settings
LEMON_SQUEEZY_API_KEY=                         # Profile → API Keys
LEMON_SQUEEZY_STORE_ID=                        # Store → General
LEMON_SQUEEZY_SIGNING_SECRET=                  # Webhooks → Signing Secret

# Product variant IDs (Lemon Squeezy → Products → Variants)
LEMON_SQUEEZY_STARTER_VARIANT_ID=
LEMON_SQUEEZY_GROWTH_VARIANT_ID=
LEMON_SQUEEZY_BUSINESS_VARIANT_ID=

# Checkout URLs for the BillingController upgrade redirects
LEMON_SQUEEZY_STARTER_CHECKOUT_URL=
LEMON_SQUEEZY_GROWTH_CHECKOUT_URL=
LEMON_SQUEEZY_BUSINESS_CHECKOUT_URL=

# ── AppSumo (Phase 7) ─────────────────────────────────────────────────
# No API key needed — codes are imported from CSV manually.
# Webhook for refund notifications (set in AppSumo seller dashboard):
APPSUMO_WEBHOOK_SECRET=                        # Random string — verify incoming webhook signatures

# ── Horizon (Queue Dashboard) ────────────────────────────────────────
HORIZON_PATH=horizon                           # Access at venqore.com/horizon (super-admin only)
HORIZON_PREFIX=venqore_horizon:                # Redis key prefix — change if running multiple apps
# Slack webhook for failed job notifications (Pre-Launch §14)
HORIZON_SLACK_WEBHOOK=                         # Same or different webhook from LOG_SLACK_WEBHOOK_URL
HORIZON_ALERT_EMAIL=                           # Email to notify on queue failures

# ── Maintenance ───────────────────────────────────────────────────────
APP_MAINTENANCE_DRIVER=file

VITE_APP_NAME="${APP_NAME}"
